# ─── Core ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database & Cache ─────────────────────────────────────────
DATABASE_URL=postgresql://caresync:caresync@localhost:5432/caresync
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters.
JWT_SECRET=dev_jwt_secret_change_me_minimum_32_chars_long_0
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Third-party (optional in Phase 1) ────────────────────────
ANTHROPIC_API_KEY=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
