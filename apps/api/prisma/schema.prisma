generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  PRIMARY_CAREGIVER
  SECONDARY_CAREGIVER
  FAMILY_MEMBER
  MEDICAL_COORDINATOR
  FINANCIAL_COORDINATOR
  CARE_RECIPIENT
}

enum CareStatus {
  ACTIVE
  INACTIVE
  EMERGENCY
  HOSPICE
  DECEASED
}

enum TaskStatus {
  PENDING
  COMPLETED
  MISSED
  SKIPPED
}

enum TaskFrequency {
  ONE_TIME
  DAILY
  TWICE_DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum LogEntryType {
  MEAL
  WATER
  MEDICATION
  BATHROOM
  SLEEP
  MOOD
  PAIN
  FALL
  BEHAVIORAL
  MEDICAL_NOTE
  VITAL_SIGNS
  GENERAL
}

enum MedicationFrequency {
  DAILY
  TWICE_DAILY
  THREE_TIMES_DAILY
  FOUR_TIMES_DAILY
  EVERY_OTHER_DAY
  WEEKLY
  AS_NEEDED
  CUSTOM
}

enum DocumentType {
  ADVANCE_DIRECTIVE
  DNR_ORDER
  INSURANCE_CARD
  MEDICAL_RECORD
  PRESCRIPTION
  LEGAL_DOCUMENT
  PHOTO
  OTHER
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum SubscriptionPlan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  PAUSED
}

enum BlueprintTriggerType {
  FALL
  HOSPITALIZATION
  HOSPICE_TRANSITION
  CAREGIVER_BURNOUT
  PRIMARY_CAREGIVER_UNAVAILABLE
  BEHAVIORAL_CRISIS
  CUSTOM
}

// ─────────────────────────────────────────────
// AUTH MODELS (NextAuth compatible)
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  firstName       String
  lastName        String
  phone           String?
  avatarUrl       String?
  emailVerified   DateTime?
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  careTeamMemberships   CareTeamMember[]
  createdLogs           CareLog[]          @relation("LogCreator")
  assignedTasks         TaskAssignment[]
  createdTasks          Task[]             @relation("TaskCreator")
  uploadedDocuments     Document[]
  shiftHandoffsGiven    ShiftHandoff[]     @relation("HandoffGiver")
  shiftHandoffsReceived ShiftHandoff[]     @relation("HandoffReceiver")
  notifications         Notification[]
  auditLogs             AuditLog[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// CARE TEAM & ORGANIZATION
// ─────────────────────────────────────────────

model CareTeam {
  id          String     @id @default(uuid())
  name        String
  description String?
  status      CareStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  recipient    CareRecipient?
  members      CareTeamMember[]
  subscription Subscription?
  invites      TeamInvite[]

  @@map("care_teams")
}

model CareTeamMember {
  id         String   @id @default(uuid())
  careTeamId String
  userId     String
  role       UserRole
  isAdmin    Boolean  @default(false)
  joinedAt   DateTime @default(now())
  invitedBy  String?

  careTeam CareTeam @relation(fields: [careTeamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([careTeamId, userId])
  @@index([careTeamId])
  @@index([userId])
  @@map("care_team_members")
}

model TeamInvite {
  id         String   @id @default(uuid())
  careTeamId String
  email      String
  role       UserRole
  token      String   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())

  careTeam CareTeam @relation(fields: [careTeamId], references: [id], onDelete: Cascade)

  @@index([careTeamId])
  @@index([token])
  @@index([email])
  @@map("team_invites")
}

// ─────────────────────────────────────────────
// CARE RECIPIENT
// ─────────────────────────────────────────────

model CareRecipient {
  id                    String     @id @default(uuid())
  careTeamId            String     @unique
  firstName             String
  lastName              String
  dateOfBirth           DateTime?
  avatarUrl             String?
  primaryDiagnosis      String?
  secondaryDiagnoses    String[]
  allergies             String[]
  bloodType             String?
  weightLbs             Float?
  heightInches          Float?
  preferredHospital     String?
  preferredPhysician    String?
  physicianPhone        String?
  insuranceProvider     String?
  insurancePolicyNumber String?
  insuranceGroupNumber  String?
  medicareNumber        String?
  medicaidNumber        String?
  dnrStatus             Boolean    @default(false)
  advanceDirective      Boolean    @default(false)
  advanceDirectiveUrl   String?
  mobilityStatus        String?
  dietaryRestrictions   String[]
  notes                 String?    @db.Text
  status                CareStatus @default(ACTIVE)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  careTeam          CareTeam          @relation(fields: [careTeamId], references: [id])
  medications       Medication[]
  careLogs          CareLog[]
  tasks             Task[]
  appointments      Appointment[]
  documents         Document[]
  emergencyContacts EmergencyContact[]
  inventory         InventoryItem[]
  futureBlueprints  FutureBlueprint[]
  vitalSigns        VitalSign[]
  shiftHandoffs     ShiftHandoff[]

  @@index([careTeamId])
  @@map("care_recipients")
}

model EmergencyContact {
  id             String  @id @default(uuid())
  recipientId    String
  name           String
  relationship   String
  phone          String
  alternatePhone String?
  email          String?
  isLocalContact Boolean @default(false)
  priority       Int     @default(1)
  notes          String?

  recipient CareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@map("emergency_contacts")
}

// ─────────────────────────────────────────────
// MEDICATIONS
// ─────────────────────────────────────────────

model Medication {
  id              String              @id @default(uuid())
  recipientId     String
  name            String
  genericName     String?
  dosage          String
  unit            String
  frequency       MedicationFrequency
  customFrequency String?
  instructions    String?             @db.Text
  prescribedBy    String?
  pharmacy        String?
  pharmacyPhone   String?
  rxNumber        String?
  refillDate      DateTime?
  pillsRemaining  Int?
  startDate       DateTime            @default(now())
  endDate         DateTime?
  isActive        Boolean             @default(true)
  isPRN           Boolean             @default(false)
  prnReason       String?
  sideEffects     String[]
  purpose         String?
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  recipient      CareRecipient        @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  logs           MedicationLog[]
  scheduleTimes  MedicationSchedule[]

  @@index([recipientId])
  @@index([isActive])
  @@map("medications")
}

model MedicationSchedule {
  id            String   @id @default(uuid())
  medicationId  String
  scheduledTime String
  label         String?

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
  @@map("medication_schedules")
}

model MedicationLog {
  id             String   @id @default(uuid())
  medicationId   String
  administeredBy String
  administeredAt DateTime @default(now())
  scheduled      Boolean  @default(true)
  given          Boolean  @default(true)
  dosageGiven    String?
  reason         String?
  notes          String?

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
  @@index([administeredAt])
  @@map("medication_logs")
}

// ─────────────────────────────────────────────
// CARE LOGS
// ─────────────────────────────────────────────

model CareLog {
  id          String       @id @default(uuid())
  recipientId String
  loggedBy    String
  type        LogEntryType
  occurredAt  DateTime     @default(now())
  notes       String?      @db.Text

  mealDescription       String?
  mealAmount            String?
  waterOz               Float?
  urination             Boolean?
  bowelMovement         Boolean?
  bowelDescription      String?
  sleepHours            Float?
  sleepQuality          String?
  moodRating            Int?
  moodDescription       String?
  painLevel             Int?
  painLocation          String?
  painDescription       String?
  fallLocation          String?
  fallInjury            Boolean?
  fallInjuryDescription String?
  emergencyContacted    Boolean?
  behaviorDescription   String?
  behaviorTrigger       String?
  behaviorIntervention  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipient    CareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  loggedByUser User          @relation("LogCreator", fields: [loggedBy], references: [id])

  @@index([recipientId])
  @@index([loggedBy])
  @@index([occurredAt])
  @@index([type])
  @@map("care_logs")
}

model VitalSign {
  id                     String   @id @default(uuid())
  recipientId            String
  recordedBy             String
  recordedAt             DateTime @default(now())
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  heartRate              Int?
  temperatureF           Float?
  oxygenSaturation       Int?
  bloodSugar             Float?
  weightLbs              Float?
  notes                  String?

  recipient CareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([recordedAt])
  @@map("vital_signs")
}

// ─────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────

model Task {
  id             String        @id @default(uuid())
  recipientId    String
  createdBy      String
  title          String
  description    String?       @db.Text
  frequency      TaskFrequency @default(ONE_TIME)
  customSchedule String?
  dueDate        DateTime?
  dueTime        String?
  isRecurring    Boolean       @default(false)
  priority       Int           @default(2)
  category       String?
  instructions   String?       @db.Text
  suppliesNeeded String[]
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  recipient   CareRecipient    @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  creator     User             @relation("TaskCreator", fields: [createdBy], references: [id])
  assignments TaskAssignment[]

  @@index([recipientId])
  @@index([dueDate])
  @@map("tasks")
}

model TaskAssignment {
  id          String     @id @default(uuid())
  taskId      String
  userId      String
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  skippedAt   DateTime?
  skipReason  String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@map("task_assignments")
}

// ─────────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────────

model Appointment {
  id                      String    @id @default(uuid())
  recipientId             String
  title                   String
  provider                String?
  specialty               String?
  location                String?
  address                 String?
  phone                   String?
  scheduledAt             DateTime
  durationMinutes         Int?
  notes                   String?   @db.Text
  preparationInstructions String?   @db.Text
  transportation          String?
  transportedBy           String?
  isCompleted             Boolean   @default(false)
  completedAt             DateTime?
  outcome                 String?   @db.Text
  followUpRequired        Boolean   @default(false)
  followUpNotes           String?
  reminderSent            Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  recipient CareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([scheduledAt])
  @@map("appointments")
}

// ─────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────

model Document {
  id          String       @id @default(uuid())
  recipientId String
  uploadedBy  String
  type        DocumentType
  title       String
  description String?
  fileUrl     String
  fileName    String
  fileSize    Int
  mimeType    String
  isEncrypted Boolean      @default(true)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  recipient CareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  uploader  User          @relation(fields: [uploadedBy], references: [id])

  @@index([recipientId])
  @@index([type])
  @@map("documents")
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model InventoryItem {
  id            String    @id @default(uuid())
  recipientId   String
  name          String
  category      String
  location      String?
  currentStock  Int       @default(0)
  minimumStock  Int       @default(1)
  unit          String    @default("units")
  supplierName  String?
  supplierUrl   String?
  notes         String?
  isActive      Boolean   @default(true)
  lastRestocked DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recipient    CareRecipient         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  transactions InventoryTransaction[]

  @@index([recipientId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id         String   @id @default(uuid())
  itemId     String
  type       String
  quantity   Int
  notes      String?
  recordedBy String
  recordedAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("inventory_transactions")
}

// ─────────────────────────────────────────────
// SHIFT HANDOFFS
// ─────────────────────────────────────────────

model ShiftHandoff {
  id               String   @id @default(uuid())
  recipientId      String
  giverId          String
  receiverId       String?
  shiftDate        DateTime @default(now())
  shiftType        String?
  summary          String   @db.Text
  mealsGiven       String?
  waterIntake      String?
  medicationsGiven String?
  medicationsMissed String?
  bowelMovements   String?
  sleep            String?
  mood             String?
  painLevel        Int?
  falls            String?
  behavioralNotes  String?  @db.Text
  pendingTasks     String?  @db.Text
  upcomingAppointments String?
  suppliesLow      String[]
  urgentItems      String?  @db.Text
  generalNotes     String?  @db.Text
  isRead           Boolean  @default(false)
  readAt           DateTime?
  createdAt        DateTime @default(now())

  recipient CareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  giver     User          @relation("HandoffGiver", fields: [giverId], references: [id])
  receiver  User?         @relation("HandoffReceiver", fields: [receiverId], references: [id])

  @@index([recipientId])
  @@index([giverId])
  @@index([shiftDate])
  @@map("shift_handoffs")
}

// ─────────────────────────────────────────────
// FUTURE CARE BLUEPRINTS
// ─────────────────────────────────────────────

model FutureBlueprint {
  id            String               @id @default(uuid())
  recipientId   String
  title         String
  trigger       BlueprintTriggerType
  customTrigger String?
  description   String?              @db.Text
  steps         Json
  contacts      Json
  documents     String[]
  isActive      Boolean              @default(true)
  lastReviewed  DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  recipient CareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@map("future_blueprints")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  title     String
  body      String              @db.Text
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS & BILLING
// ─────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid())
  careTeamId           String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  careTeam CareTeam @relation(fields: [careTeamId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// FEATURE FLAGS
// ─────────────────────────────────────────────

model FeatureFlag {
  id             String             @id @default(uuid())
  name           String             @unique
  description    String?
  isEnabled      Boolean            @default(false)
  rolloutPercent Int                @default(0)
  allowedPlans   SubscriptionPlan[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("feature_flags")
}

// ─────────────────────────────────────────────
// AUDIT LOG (HIPAA)
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}
