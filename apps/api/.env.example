NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://caresync:caresync@localhost:5432/caresync
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev_jwt_secret_change_me_minimum_32_chars_long_0
JWT_EXPIRES_IN=7d
# Must match NEXTAUTH_SECRET in apps/web/.env.local (min 32 chars).
NEXTAUTH_SECRET=generate_with_node_crypto_randomBytes_32_base64
NEXTAUTH_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
# Supabase Storage (Project Settings → API): URL + service_role key for document storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
